# ============================================
# HOTMART DASHBOARD - Configurações
# ============================================

# Token de acesso da API Hotmart
# Como obter: Hotmart > Ferramentas > API Tokens
HOTMART_TOKEN=seu_token_aqui

# Client ID e Secret (necessários para renovar token OAuth2)
HOTMART_CLIENT_ID=seu_client_id_aqui
HOTMART_CLIENT_SECRET=seu_client_secret_aqui
HOTMART_BASIC_AUTH=seu_basic_auth_base64_aqui

# Ambiente: 'sandbox' para testes ou 'production' para produção
HOTMART_ENV=production

# Porta do servidor (padrão: 3000)
PORT=3000

# Tempo de cache em segundos (padrão: 300 = 5 minutos)
CACHE_TTL=300

# Usar dados mock em vez da API real (true/false)
# Se true, lê o arquivo mock-sales.json na raiz do projeto
USE_MOCK=true
